<!-- Diagonal transition from cream to dark -->
<div class="h-16" style="background: linear-gradient(to bottom right, var(--color-cream-dark) 49.5%, var(--color-charcoal) 50%);"></div>

<section id="contact" class="py-20 md:py-28 bg-charcoal text-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-terracotta-light font-semibold mb-3">Parlons de votre projet</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Contactez-moi</h2>
      <div class="w-16 h-1 bg-terracotta rounded-full mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
      {/* Formulaire */}
      <form
        action="https://formspree.io/f/mdayewgn"
        method="POST"
        class="space-y-6 animate-on-scroll stagger-1"
      >
        <div>
          <label for="name" class="block text-sm font-medium mb-2 text-white/80">Nom</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-xl border border-white/20 bg-white/10 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-terracotta/50 focus:border-terracotta transition-colors"
            placeholder="Votre nom"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-2 text-white/80">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-xl border border-white/20 bg-white/10 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-terracotta/50 focus:border-terracotta transition-colors"
            placeholder="votre@email.com"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium mb-2 text-white/80">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 rounded-xl border border-white/20 bg-white/10 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-terracotta/50 focus:border-terracotta transition-colors resize-none"
            placeholder="Décrivez votre projet..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-8 py-4 bg-terracotta text-white font-semibold rounded-xl hover:bg-terracotta-dark hover:scale-[1.02] hover:shadow-xl hover:shadow-terracotta/40 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-terracotta/20"
        >
          Envoyer le message
        </button>
      </form>

      {/* Coordonnées */}
      <div class="flex flex-col justify-center space-y-8 animate-on-scroll stagger-2">
        <div>
          <h3 class="font-bold text-lg mb-4 text-white">Autres moyens de me joindre</h3>
          <p class="text-white/60 leading-relaxed mb-6">
            N'hésitez pas à me contacter directement par email ou via le formulaire.
            Je réponds généralement sous 24h.
          </p>
        </div>

        <div class="space-y-4">
          <a href="mailto:contact@mouilleronweb.fr" class="flex items-center gap-4 text-white/70 hover:text-terracotta-light transition-colors group">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center group-hover:bg-terracotta/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-terracotta-light">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <span>contact@mouilleronweb.fr</span>
          </a>

          <a href="https://www.linkedin.com/in/mouilleron/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 text-white/70 hover:text-terracotta-light transition-colors group">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center group-hover:bg-terracotta/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-terracotta-light">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
