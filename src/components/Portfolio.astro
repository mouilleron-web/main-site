---
const projects = [
  {
    title: "Boulangerie du Quartier",
    category: "Site vitrine",
    description: "Un site chaleureux mettant en avant les produits artisanaux et les horaires d'ouverture.",
    color: "bg-terracotta/10",
  },
  {
    title: "Salon Éclat",
    category: "Site vitrine",
    description: "Un design élégant pour un salon de coiffure avec prise de rendez-vous en ligne.",
    color: "bg-amber-100",
  },
  {
    title: "Cave & Saveurs",
    category: "Refonte",
    description: "Modernisation complète du site d'un caviste avec catalogue de vins et événements.",
    color: "bg-emerald-100",
  },
];
---

<section id="portfolio" class="py-20 md:py-28 bg-cream-dark">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-terracotta font-semibold mb-3">Mon travail</p>
      <h2 class="text-3xl md:text-4xl font-bold">Réalisations</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300">
          <div class={`${project.color} h-52 flex items-center justify-center`}>
            <div class="w-16 h-16 bg-white/60 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-charcoal-light">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21z" />
              </svg>
            </div>
          </div>
          <div class="p-6">
            <span class="text-sm text-terracotta font-medium">{project.category}</span>
            <h3 class="text-lg font-bold mt-1 mb-2">{project.title}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{project.description}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-warm-gray mt-12 text-sm">
      Ces projets sont des exemples. Votre site sera unique et conçu sur mesure.
    </p>
  </div>
</section>
