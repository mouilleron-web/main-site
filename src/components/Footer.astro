---
const year = new Date().getFullYear();
---

<footer class="bg-gradient-to-b from-charcoal to-charcoal-deep text-white/70 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-0">
        <span class="text-sm font-semibold tracking-widest uppercase text-terracotta-light">MOUILLERON</span>
        <span class="w-6 h-0.5 bg-white/30 mx-2.5"></span>
        <span class="text-sm font-light tracking-widest uppercase text-white/60">WEB</span>
        <span class="mx-4 text-white/20">|</span>
        <span class="text-sm text-white/50">Développeur Web Freelance</span>
      </div>

      <div class="flex items-center gap-6">
        <nav>
          <ul class="flex items-center gap-6 text-sm">
            <li><a href="#accueil" class="nav-link hover:text-white transition-colors">Accueil</a></li>
            <li><a href="#services" class="nav-link hover:text-white transition-colors">Services</a></li>
            <li><a href="#portfolio" class="nav-link hover:text-white transition-colors">Portfolio</a></li>
            <li><a href="#contact" class="nav-link hover:text-white transition-colors">Contact</a></li>
          </ul>
        </nav>

        <a href="#accueil" class="w-10 h-10 rounded-full bg-terracotta/20 flex items-center justify-center hover:bg-terracotta/40 transition-colors" aria-label="Retour en haut">
          <svg class="w-5 h-5 text-terracotta-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
          </svg>
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 mt-8 pt-8 text-center text-sm text-white/40">
      <p>&copy; {year} Cédric Mouilleron. Tous droits réservés.</p>
    </div>
  </div>
</footer>
