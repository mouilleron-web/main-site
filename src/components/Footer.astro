    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <span class="text-xl font-bold text-terracotta-light">CM</span>
        <span class="text-white/40">.</span>
        <span class="text-sm">Développeur Web Freelance</span>
      </div>

      <nav>
        <ul class="flex items-center gap-6 text-sm">
          <li><a href="#accueil" class="hover:text-white transition-colors">Accueil</a></li>
          <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="#portfolio" class="hover:text-white transition-colors">Portfolio</a></li>
