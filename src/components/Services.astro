---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: "Création de site",
    description: "Un site vitrine unique et moderne qui reflète l'identité de votre activité et attire vos clients."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>`,
    title: "Refonte",
    description: "Votre site actuel est vieillissant ? Je le modernise avec un design frais et des performances optimales."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
    title: "Responsive & Mobile",
    description: "Chaque site est pensé pour s'afficher parfaitement sur mobile, tablette et ordinateur."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>`,
    title: "Référencement (SEO)",
    description: "Être trouvé sur Google quand un client cherche « plombier Grenoble » ou « boulangerie près de chez moi ». J'optimise chaque page — titres, descriptions, vitesse de chargement, fiche Google Business — pour que votre site apparaisse dans les premiers résultats."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" /></svg>`,
    title: "Hébergement",
    description: "Nom de domaine, mise en ligne, certificat de sécurité : je m'occupe de tout. Vous n'avez rien à gérer, votre site est en ligne et accessible 24h/24."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.653-4.655m0 0a2.678 2.678 0 0 1 .766-1.208l3.03-2.496M21 3l-3.504 2.1-5.533.631 1.328 1.329-1.548 1.879" /></svg>`,
    title: "Maintenance",
    description: "Mises à jour, corrections, ajout de contenu : je reste disponible après la livraison de votre site."
  }
];
---

<section id="services" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-terracotta font-semibold mb-3 text-sm tracking-[0.2em] uppercase">Ce que je propose</p>
      <h2 class="text-3xl md:text-4xl font-bold">Mes services</h2>
      <div class="w-16 h-1 bg-terracotta rounded-full mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <div class={`group relative p-8 rounded-2xl border border-cream-dark hover:border-terracotta/40 transition-all duration-300 animate-on-scroll stagger-${i + 1} bg-gradient-to-br from-cream to-cream-dark/50 hover:from-cream hover:to-terracotta/5`}>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-11 h-11 rounded-full bg-terracotta/10 flex items-center justify-center text-terracotta group-hover:bg-terracotta group-hover:text-white transition-all duration-300">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-lg font-bold">{service.title}</h3>
          </div>
          <p class="text-warm-gray text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
